{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veilforge.dev/schemas/policy-manifest.schema.json",
  "title": "VeilForge Arc Policy Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedBy",
    "sourceHash",
    "reportHash",
    "readinessScore",
    "triageStatus",
    "selectors"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "generatedBy": { "type": "string", "minLength": 1 },
    "sourceHash": { "$ref": "#/$defs/hash" },
    "reportHash": { "$ref": "#/$defs/hash" },
    "readinessScore": { "type": "integer", "minimum": 0, "maximum": 100 },
    "triageStatus": { "$ref": "#/$defs/triageStatus" },
    "selectors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["contractName", "file", "signature", "policy", "confidence", "reason"],
        "properties": {
          "contractName": { "type": "string" },
          "file": { "type": "string" },
          "signature": { "type": "string" },
          "policy": { "enum": ["open", "restricted", "locked"] },
          "confidence": { "enum": ["high", "medium", "low"] },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "triageStatus": { "enum": ["ready", "review-required", "high-risk", "deployment-blocked"] }
  },
  "additionalProperties": false
}
